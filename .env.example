# ============================================
# Xin AI Consultant - 环境配置模板
# ============================================
# 复制为 .env 并填入实际值：Copy-Item .env.example .env

# --- 管理员 ---
ADMIN_PASSWORD=admin123

# --- 数据库 ---
# sqlite = 零依赖（默认），mysql = 需要 MySQL 8.0 服务
DB_BACKEND=sqlite

# MySQL 配置（仅 DB_BACKEND=mysql 时生效）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=xin_ai
DB_USER=xin_user
DB_PASSWORD=xin_pass_2026

# --- Redis ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

# --- LLM 主模型 ---
# 支持的 provider: dashscope(阿里云百炼) / deepseek / openai / anthropic / ollama
# 阿里云百炼 Coding Plan 示例：
LLM_PROVIDER=dashscope
LLM_MODEL=qwen3.5-plus
LLM_API_KEY=sk-xxx-your-api-key-here
LLM_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# DeepSeek 示例：
# LLM_PROVIDER=deepseek
# LLM_MODEL=deepseek-chat
# LLM_API_KEY=sk-xxx
# LLM_BASE_URL=https://api.deepseek.com/v1

# --- Embedding 模型 ---
# local = 本地 CPU 推理（bge-small-zh，无需 GPU，推荐测试环境使用）
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_DIMENSION=512

# --- Ollama 本地模型（可选）---
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://127.0.0.1:11435/v1
OLLAMA_MODEL=qwen2.5:3b

# --- JWT 认证 ---
JWT_SECRET_KEY=change-this-to-a-random-string-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- 服务端口 ---
BACKEND_PORT=8000
FRONTEND_PORT=3000
